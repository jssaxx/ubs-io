+TEST_F(StorageBackendTest, DistributedKVStorageBackend_BatchLoad_Basic) {
+    FileStorageConfig config;
+    config.storage_backend_type = StorageBackendType::kDistributedKV;
+    config.total_size_limit = 100 * 1024 * 1024;
